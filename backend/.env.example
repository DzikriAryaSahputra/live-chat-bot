# Konfigurasi Server Node.js
PORT=3000

# Konfigurasi Database PostgreSQL
DB_USER=postgres
DB_PASSWORD=password_database_production
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bps_chatbot

# Keamanan (JSON Web Token)
JWT_SECRET=GANTI_DENGAN_STRING_ACAK_YANG_KUAT_DAN_PANJANG

# API Keys LLM (Untuk RAG BPS)
# Dapatkan Groq API Key dari: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx...

# Dapatkan Gemini API Key dari: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Endpoint Rasa (Default lokal)
RASA_API_URL=http://localhost:5005
